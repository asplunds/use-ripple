{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 4,
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules",
    "ripple.js",
    "ripple.d.ts",
    "pnpm-lock.yaml",
    "**/.next",
    "**/dist",
    "**/.turbo"
  ]
}
