{
  "name": "use-ripple-hook",
  "version": "2.0.0",
  "type": "module",
  "repository": {
    "url": "https://github.com/asplunds/use-ripple"
  },
  "description": "Customizable, lightweight React hook for implementing Google's Material UI style ripple effect",
  "main": "dist/ripple.js",
  "module": "dist/ripple.js",
  "types": "dist/ripple.d.ts",
  "sideEffects": false,
  "scripts": {
    "prepack": "tsc --declaration",
    "postpublish": "rm -rf dist",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "keywords": [
    "useripple",
    "use-ripple",
    "material",
    "ripple",
    "react",
    "hook"
  ],
  "exports": {
    ".": {
      "types": "./dist/ripple.d.ts",
      "import": "./dist/ripple.js",
      "default": "./dist/ripple.js"
    }
  },
  "author": "Jonathan Asplund",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "readme.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "husky": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
