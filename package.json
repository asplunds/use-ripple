{
  "name": "use-ripple-hook",
  "version": "1.1.25",
  "type": "module",
  "repository": {
    "url": "https://github.com/asplunds/use-ripple"
  },
  "description": "Customizable, lightweight React hook for implementing Google's Material UI style ripple effect",
  "main": "ripple.js",
  "module": "ripple.js",
  "scripts": {
    "prepack": "tsc --declaration",
    "postpublish": "tsc --build --clean",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "keywords": [
    "useripple",
    "use-ripple",
    "material",
    "ripple",
    "react",
    "hook"
  ],
  "exports": {
    ".": {
      "types": "./ripple.d.ts",
      "import": "./ripple.js",
      "default": "./ripple.js"
    }
  },
  "author": "Jonathan Asplund",
  "license": "ISC",
  "types": "./ripple.d.ts",
  "files": [
    "ripple.js",
    "ripple.d.ts",
    "ripple.ts",
    "readme.md"
  ],
  "devDependencies": {
    "@types/react": "catalog:",
    "husky": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  }
}
